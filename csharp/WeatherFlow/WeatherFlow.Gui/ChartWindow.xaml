<Window x:Class="WeatherFlow.Gui.ChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="700" Height="420"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E" ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Foreground="#89B4FA" Margin="0,0,0,4" />

        <!-- Summary -->
        <TextBlock x:Name="SummaryText" Grid.Row="1" FontSize="12"
                   Foreground="#6C7086" Margin="0,0,0,12" />

        <!-- Chart Area -->
        <Border Grid.Row="2" Background="#2A2A3C" CornerRadius="8" Padding="0" ClipToBounds="True">
            <Grid>
                <!-- Grid lines + labels drawn in code-behind -->
                <Canvas x:Name="ChartCanvas" Margin="50,20,20,35" />

                <!-- Y-Axis labels -->
                <Canvas x:Name="YAxisCanvas" Width="45" HorizontalAlignment="Left" Margin="0,20,0,35" />

                <!-- X-Axis labels -->
                <Canvas x:Name="XAxisCanvas" Height="30" VerticalAlignment="Bottom" Margin="50,0,20,0" />
            </Grid>
        </Border>

        <!-- Hover info -->
        <TextBlock x:Name="HoverText" Grid.Row="3" FontSize="11"
                   Foreground="#6C7086" Margin="0,8,0,0" />
    </Grid>
</Window>
