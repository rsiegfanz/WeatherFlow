<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net9.0-windows</TargetFramework>
        <UseWPF>true</UseWPF>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <AssemblyName>WeatherFlow</AssemblyName>
        <ApplicationIcon />
    </PropertyGroup>

    <!-- Share Auth + Thingsboard code from console project -->
    <ItemGroup>
        <Compile Include="..\WeatherFlow\Auth\**\*.cs" Link="Auth\%(RecursiveDir)%(Filename)%(Extension)" />
        <Compile Include="..\WeatherFlow\Thingsboard\**\*.cs" Link="Thingsboard\%(RecursiveDir)%(Filename)%(Extension)" />
    </ItemGroup>

</Project>
